FROM niis/xroad-security-server-sidecar:7.8.2-secondary-fi@sha256:34e0dde7f1f210dc3e5d12407eb80b3cf8050321703add2482d692699e8b9bb6

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PRIVATE_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa && \
    chmod 644 /etc/.ssh/id_rsa && \
    /root/entrypoint.sh
