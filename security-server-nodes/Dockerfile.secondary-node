FROM niis/xroad-security-server-sidecar:7.8.0-secondary-fi@sha256:cd4194bdf6990a4c0e94cc832f6bfaf9a6c43d3bd85065d9a7e10f4720dc860e

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PRIVATE_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa && \
    chmod 644 /etc/.ssh/id_rsa && \
    /root/entrypoint.sh
