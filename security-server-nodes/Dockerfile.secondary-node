FROM niis/xroad-security-server-sidecar:7.8.1-secondary-fi@sha256:27222c931cc49996a2a901f8114f2b0191019a73f1b61a22903ed959e6fb503e

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PRIVATE_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa && \
    chmod 644 /etc/.ssh/id_rsa && \
    /root/entrypoint.sh
