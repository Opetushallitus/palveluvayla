FROM niis/xroad-security-server-sidecar:7.8.0-secondary-fi@sha256:a4bf1fcbde11087c73e54f98ed461a8cc210fd50a18a30bc62dd9aee07bb9f97

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PRIVATE_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa && \
    chmod 644 /etc/.ssh/id_rsa && \
    /root/entrypoint.sh
