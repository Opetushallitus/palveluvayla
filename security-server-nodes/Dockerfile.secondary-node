FROM niis/xroad-security-server-sidecar:7.8.0-secondary-fi@sha256:b56910fe851af4f34becb0fa9dd718d46827587fa8951bfaa6a22849a9916a24

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PRIVATE_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa && \
    chmod 644 /etc/.ssh/id_rsa && \
    /root/entrypoint.sh
