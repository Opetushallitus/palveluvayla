FROM niis/xroad-security-server-sidecar:7.8.0-primary-fi@sha256:d633e343bca1247c073f5a6d28585eee478edc6d8c751ae6915ea8e570ca3f61

COPY ./local.ini /root/local.ini

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PUBLIC_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa.pub && \
    chmod 644 /etc/.ssh/id_rsa.pub && \
    cp /root/local.ini /etc/xroad/conf.d/local.ini && \
    /root/entrypoint.sh
