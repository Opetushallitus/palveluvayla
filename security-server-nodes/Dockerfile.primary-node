FROM niis/xroad-security-server-sidecar:7.8.1-primary-fi@sha256:7eaa38ab3e7bc509b437d1c58953612b53cbe0732773deea32b6254c174aaf95

COPY ./local.ini /root/local.ini

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PUBLIC_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa.pub && \
    chmod 644 /etc/.ssh/id_rsa.pub && \
    cp /root/local.ini /etc/xroad/conf.d/local.ini && \
    /root/entrypoint.sh
