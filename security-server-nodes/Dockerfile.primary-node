FROM niis/xroad-security-server-sidecar:7.5.1-primary-fi@sha256:6dfcd7f8150eaa4b74f47264f1f9b7da3f327681f337079eaa36b00239fa4c70

COPY ./local.ini /root/local.ini

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PUBLIC_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa.pub && \
    chmod 644 /etc/.ssh/id_rsa.pub && \
    cp /root/local.ini /etc/xroad/conf.d/local.ini && \
    /root/entrypoint.sh
