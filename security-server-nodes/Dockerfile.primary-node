FROM niis/xroad-security-server-sidecar:7.5.1-primary-fi@sha256:d2989d9216843bb880469740ae93ba4f2d9185119be9db45ef421b92e11f5e2c

COPY ./local.ini /root/local.ini

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PUBLIC_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa.pub && \
    chmod 644 /etc/.ssh/id_rsa.pub && \
    cp /root/local.ini /etc/xroad/conf.d/local.ini && \
    /root/entrypoint.sh
