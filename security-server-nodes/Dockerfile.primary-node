FROM niis/xroad-security-server-sidecar:7.8.0-primary-fi@sha256:a3098d3326af09a148230d6c0b3d1a1527415213bc3872cc4b898fac342c5be0

COPY ./local.ini /root/local.ini

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PUBLIC_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa.pub && \
    chmod 644 /etc/.ssh/id_rsa.pub && \
    cp /root/local.ini /etc/xroad/conf.d/local.ini && \
    /root/entrypoint.sh
