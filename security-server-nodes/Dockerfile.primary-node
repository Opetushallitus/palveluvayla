FROM niis/xroad-security-server-sidecar:7.8.1-primary-fi@sha256:045881fff983ccc0908d332e1a2f017ed1c7946cf7049c49bac83be92f8dba4f

COPY ./local.ini /root/local.ini

CMD mkdir /etc/.ssh && \
    chmod 755 /etc/.ssh && \
    echo -n ${SSH_PUBLIC_KEY_BASE64} | base64 --decode > /etc/.ssh/id_rsa.pub && \
    chmod 644 /etc/.ssh/id_rsa.pub && \
    cp /root/local.ini /etc/xroad/conf.d/local.ini && \
    /root/entrypoint.sh
